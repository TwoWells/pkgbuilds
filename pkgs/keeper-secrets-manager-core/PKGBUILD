# shellcheck shell=bash disable=SC2034,SC2154
pkgname=keeper-secrets-manager-core
pkgver=17.2.1
pkgrel=1
pkgdesc="Keeper Secrets Manager SDK core module"
arch=('any')
url="https://github.com/Keeper-Security/secrets-manager"
license=('MIT')
depends=(
    'python'
    'python-requests'
    'python-cryptography>=39.0.1'
    'python-importlib-metadata'
    'python-urllib3>=2.6.0'
)
makedepends=(
    'python-build'
    'python-installer'
    'python-setuptools'
)
source=("https://files.pythonhosted.org/packages/source/k/keeper_secrets_manager_core/keeper_secrets_manager_core-$pkgver.tar.gz")
sha512sums=('a71a3053ce906a4dc77220e1be2362cde8dbb14782731c4f49c60499d9d1f1cbce6177ad199206df21df7fc51f60177e95beabaa5d287d6e8fb973fcaf3b98f2')

build() {
    cd "keeper_secrets_manager_core-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "keeper_secrets_manager_core-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
}
